{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2019",
    "moduleResolution": "node",
    "module": "ESNext",
    "jsx": "react-jsx",
    "types": ["node", "jest"],
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
  },
  "include": ["src", "jest.config.js"]
}